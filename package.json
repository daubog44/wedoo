{
  "name": "wedoo-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "loop:check": "node scripts/loop-ready.mjs",
    "loop:assets": "node scripts/figma-section-assets-report.mjs",
    "loop:nodes": "node scripts/prd-node-report.mjs",
    "loop:prompt": "node scripts/print-loop-prompt.mjs",
    "loop:ready": "node scripts/loop-ready.mjs && npm run test:all",
    "loop:worklog": "node scripts/loop-worklog-path.mjs",
    "typecheck": "tsc -b && tsc -p tsconfig.test.json --noEmit",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=chromium-desktop",
    "test:e2e:mobile": "playwright test --project=chromium-mobile",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:vrt": "playwright test tests/e2e/parity --grep \"visual parity\"",
    "test:vrt:update": "playwright test tests/e2e/parity --grep \"visual parity\" --update-snapshots",
    "test:integration": "vitest run",
    "test:integration:watch": "vitest",
    "test:all": "npm run lint && npm run typecheck && npm run test:integration && npm run test:e2e && npm run test:vrt"
  },
  "dependencies": {
    "@fontsource/oxygen": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/ubuntu": "^5.2.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
